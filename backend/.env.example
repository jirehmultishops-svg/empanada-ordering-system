# Server
PORT=3000

# Database (use DATABASE_URL or individual variables)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/empanadas_dev
# DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/empanadas_test

# Or individual DB connection variables
DB_HOST=localhost
DB_PORT=5432
DB_NAME=empanadas_dev
DB_NAME_TEST=empanadas_test
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Bank Transfer Details
BANK_ALIAS=empanadas.alias
BANK_CBU=0000000000000000000000

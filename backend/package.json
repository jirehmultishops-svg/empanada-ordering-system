{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx node_modules/.bin/knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "tsx node_modules/.bin/knex migrate:rollback --knexfile knexfile.ts",
    "migrate:make": "tsx node_modules/.bin/knex migrate:make --knexfile knexfile.ts -x ts"
  },
  "dependencies": {
    "bcrypt": "5.1.1",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "jsonwebtoken": "9.0.2",
    "knex": "^3.3.0",
    "multer": "1.4.5-lts.1",
    "pg": "8.11.5"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.6",
    "@types/multer": "1.4.11",
    "@types/pg": "8.11.5",
    "@types/supertest": "6.0.2",
    "fast-check": "3.17.2",
    "supertest": "6.3.4",
    "tsx": "4.9.3",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
